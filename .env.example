# Public site URL (production)
NEXT_PUBLIC_SITE_URL=https://mlsgpt.com

# Optional: Stripe Checkout fallback if you prefer a hosted payment link.
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=

# OpenAI generation
