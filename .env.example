# Public site URL (production)
NEXT_PUBLIC_SITE_URL=https://mlsgpt.com

# Optional: Stripe Checkout fallback if you prefer a hosted payment link.
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=

# OpenAI generation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Stripe recurring billing
STRIPE_SECRET_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# Signing key for paid-access cookie issuance (use a long random value)
ACCESS_TOKEN_SECRET=

# Optional Webhook secret if you add subscription provisioning
STRIPE_WEBHOOK_SECRET=
